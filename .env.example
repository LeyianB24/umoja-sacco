# =============================================================================
# USMS Environment Configuration - Copy to .env.local and fill in real values
# =============================================================================
# NOTE: .env.local is git-ignored and should NEVER be committed
# This file (.env.example) serves as a template for developers

# ────────────────────────────────────────────────────────────────────────────
# APPLICATION ENVIRONMENT
# ────────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET=your-very-long-random-secret-key-here-minimum-32-chars

# ────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (MySQL)
# ────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=umoja_drivers_sacco
DB_CHARSET=utf8mb4

# ────────────────────────────────────────────────────────────────────────────
# EMAIL / SMTP CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=Umoja Drivers Sacco

# ────────────────────────────────────────────────────────────────────────────
# M-PESA SANDBOX CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
MPESA_SANDBOX_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_SANDBOX_CONSUMER_KEY=your-sandbox-consumer-key
MPESA_SANDBOX_CONSUMER_SECRET=your-sandbox-consumer-secret
MPESA_SANDBOX_SHORTCODE=174379
MPESA_SANDBOX_PASSKEY=your-sandbox-passkey
MPESA_SANDBOX_CALLBACK_URL=https://your-domain.com/usms/public/member/mpesa_callback.php
MPESA_SANDBOX_B2C_SHORTCODE=600981
MPESA_SANDBOX_B2C_INITIATOR_NAME=testapi
MPESA_SANDBOX_B2C_SECURITY_CREDENTIAL=your-sandbox-b2c-credential
MPESA_SANDBOX_B2C_TIMEOUT_URL=https://your-domain.com/usms/public/api/b2c_timeout.php
MPESA_SANDBOX_B2C_RESULT_URL=https://your-domain.com/usms/public/api/b2c_result.php

# ────────────────────────────────────────────────────────────────────────────
# M-PESA PRODUCTION CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Only fill these when deploying to production!
MPESA_LIVE_BASE_URL=https://api.safaricom.co.ke
MPESA_LIVE_CONSUMER_KEY=your-live-consumer-key
MPESA_LIVE_CONSUMER_SECRET=your-live-consumer-secret
MPESA_LIVE_SHORTCODE=your-live-shortcode
MPESA_LIVE_PASSKEY=your-live-passkey
MPESA_LIVE_CALLBACK_URL=https://your-domain.co.ke/public/member/mpesa_callback.php
MPESA_LIVE_B2C_SHORTCODE=your-live-b2c-shortcode
MPESA_LIVE_B2C_INITIATOR_NAME=your-live-b2c-initiator
MPESA_LIVE_B2C_SECURITY_CREDENTIAL=your-live-b2c-credential
MPESA_LIVE_B2C_TIMEOUT_URL=https://your-domain.co.ke/public/api/b2c_timeout.php
MPESA_LIVE_B2C_RESULT_URL=https://your-domain.co.ke/public/api/b2c_result.php

# ────────────────────────────────────────────────────────────────────────────
# PAYSTACK CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
PAYSTACK_TEST_SECRET_KEY=sk_test_your-test-secret-key
PAYSTACK_TEST_PUBLIC_KEY=pk_test_your-test-public-key
PAYSTACK_LIVE_SECRET_KEY=sk_live_your-live-secret-key
PAYSTACK_LIVE_PUBLIC_KEY=pk_live_your-live-public-key

# ────────────────────────────────────────────────────────────────────────────
# SMS CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
SMS_ENABLED=true
SMS_SENDER_ID=UMOJA_SACCO
SMS_API_KEY=your-sms-api-key

# ────────────────────────────────────────────────────────────────────────────
# NOTIFICATION TRIGGERS
# ────────────────────────────────────────────────────────────────────────────
NOTIFY_ON_LOAN_APPROVAL=true
NOTIFY_ON_WITHDRAWAL=true
NOTIFY_ON_DEPOSIT=true
NOTIFY_ON_WELFARE_GRANT=true
